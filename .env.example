# AutoFixOps Environment Configuration
# Copy this file to .env and fill in your actual values

# PostgreSQL (NeonDB or local)
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# MongoDB Atlas
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/

# GitHub (for PR creation)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=your-username/your-infra-repo

# Shadow Mode (true = PRs are drafts, false = PRs are ready to merge)
SHADOW_MODE=true

# Prometheus
PROMETHEUS_URL=http://prometheus-operated.autofixops.svc.cluster.local:9090

# Redis
REDIS_URL=redis://localhost:6379/0

# Target Manifest Path (relative to the repo root)
TARGET_MANIFEST_PATH=kubernetes_integration/target_app/deployment.yaml
